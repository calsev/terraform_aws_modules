{% macro data(default=None) -%}
variable "dns_data" {
  type = object({
    domain_to_dns_zone_map = map(object({
      dns_zone_id = string
    }))
    domain_to_sd_zone_map = map(object({
      namespace_id = string
    }))
    region_domain_cert_map = map(map(object({
      certificate_arn = string
      name_simple     = string
    })))
  }){% if default %}
  default     = null
  description = "{{ default }}"{% endif %}
}
{%- endmacro %}
