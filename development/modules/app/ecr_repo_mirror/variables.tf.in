variable "ecr_repo_name" {
  type    = string
  default = "ecr_repo_mirror"
}

{{ iam.data() }}

variable "instance_type" {
  type    = string
  default = "t4g.micro"
}

variable "min_instances" {
  type    = number
  default = 0
}

{{ monitor.data() }}

variable "schedule_expression" {
  type    = string
  default = "cron(0 4 ? * SAT *)" # every Saturday at 4am UTC
}

{{ std.map() }}

variable "task_name" {
  type    = string
  default = "ecr_mirror"
}

{{ vpc.var() }}
