variable "alarm_map" {
  type = map(object({
    {{ alarm.var_item() }}
  }))
}

variable "alarm_map_default" {
  {{ alarm.var_default_type() }}
}

variable "alert_level_default" {
  type    = string
  default = "general_medium"
}

{{ monitor.data() }}

variable "name_map" {
  type = map(object({
    name_effective = string
  }))
}
