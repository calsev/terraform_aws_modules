variable "log_map" {
  type = map(object({
    kms_key_id              = optional(string)
    log_group_class         = optional(string)
    log_retention_days      = optional(number)
    {{ name.var_item() }}
    {{ iam.policy_var_item() }}
    skip_destroy            = optional(bool)
  }))
}

{{ log.var() }}

variable "log_skip_destroy_default" {
  type    = bool
  default = false
}

{{ name.var() }}

{{ iam.policy_var_ar(access=["write"], append="log") }}

{{ std.map() }}
