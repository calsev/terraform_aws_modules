variable "alert_level_default" {
  type    = string
  default = "general_medium"
}

{{ lambda.var_alarm_default() }}

{{ monitor.data() }}

{{ name.var() }}

{{ std.map() }}

variable "tag_filter_list" {
  type = list(string)
  default = [
    "tf.workspace",
  ]
  description = "Alarms will be configured for every lambda function that has none of these tags"
}
