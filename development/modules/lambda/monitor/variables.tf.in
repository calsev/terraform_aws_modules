variable "alert_level_default" {
  type    = string
  default = "general_medium"
}

variable "function_map" {
  type = map(object({
    {{ alarm.var_item() }}
    {{ name.var_item() }}
    name_effective = string # The name of the lambda
  }))
}

{{ lambda.var_alarm_default() }}

{{ monitor.data() }}

{{ name.var() }}

{{ std.map() }}
